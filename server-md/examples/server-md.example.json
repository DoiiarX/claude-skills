{
  "version": 1,
  "role": "canonical",
  "priority": 100,
  "markdown": "SERVER.md",
  "environment_hint": "linux",
  "tags": [
    "example",
    "main-copy"
  ],
  "execution": {
    "default_mode": "render",
    "log": "~/.server-md/ops.jsonl",
    "confirm_salt": "replace-with-local-random-value"
  },
  "servers": {
    "example-prod": {
      "aliases": [
        "prod",
        "web-prod"
      ],
      "public_host": "prod.example.com",
      "public_ip": "203.0.113.10",
      "tailnet_ip": "100.64.0.10",
      "magic_dns": "example-prod.tailnet.example",
      "identity": "~/.ssh/example_prod_key",
      "notes_file": "server-notes/example-prod.md",
      "risk": "production",
      "tags": [
        "production",
        "web"
      ],
      "warnings": [
        "Production host; prefer read-only checks before changes."
      ],
      "tips": [
        "Use server brief --name prod --tag web for compact context."
      ],
      "constraints": [
        "Do not print environment-file contents or secrets."
      ],
      "status": "active",
      "traffic_role": "primary",
      "roles": [
        "app-host",
        "production-services"
      ],
      "users": [
        "deploy",
        "ubuntu"
      ]
    },
    "example-staging": {
      "aliases": [
        "staging",
        "web-staging"
      ],
      "public_host": "staging.example.com",
      "public_ip": "203.0.113.20",
      "tailnet_ip": "100.64.0.20",
      "magic_dns": "example-staging.tailnet.example",
      "identity": "~/.ssh/example_staging_key",
      "notes_file": "server-notes/example-staging.md",
      "risk": "medium",
      "tags": [
        "staging",
        "web"
      ],
      "status": "active",
      "traffic_role": "staging",
      "roles": [
        "app-host",
        "staging"
      ],
      "users": [
        "deploy"
      ]
    }
  },
  "resources": {
    "example-prod-root": {
      "server": "example-prod",
      "kind": "project",
      "path": "/srv/example-app",
      "description": "Example application deployment root.",
      "risk": "medium",
      "tags": [
        "production",
        "web"
      ],
      "status": "active",
      "traffic_role": "primary"
    },
    "example-prod-env": {
      "server": "example-prod",
      "kind": "config",
      "path": "/etc/example-app/prod.env",
      "description": "Environment file path only; do not print contents.",
      "risk": "high",
      "tags": [
        "production",
        "secret-path"
      ],
      "warnings": [
        "Contains secrets; record only the path."
      ],
      "status": "active",
      "traffic_role": "primary"
    },
    "example-prod-db": {
      "server": "example-prod",
      "kind": "data",
      "path": "/var/lib/example-app/prod.db",
      "description": "Example production database path.",
      "risk": "high",
      "tags": [
        "production",
        "database"
      ],
      "status": "active",
      "traffic_role": "primary"
    },
    "example-old-backup": {
      "server": "example-prod",
      "kind": "backup",
      "path": "/srv/example-app/old-backups",
      "description": "Retired example backup path; retained to show lifecycle filtering.",
      "risk": "medium",
      "status": "retired",
      "traffic_role": "none",
      "tags": [
        "retired",
        "backup"
      ]
    }
  },
  "shortcuts": {
    "health": {
      "example-prod-public": {
        "host": "example-prod",
        "description": "Check example production public health endpoint.",
        "command": "curl -fsS https://prod.example.com/healthz",
        "transport": "local",
        "risk": "read-only",
        "execute_mode": "render",
        "tags": [
          "production",
          "web"
        ],
        "status": "active",
        "traffic_role": "primary"
      }
    },
    "status": {
      "example-prod-service": {
        "host": "example-prod",
        "description": "Render a read-only service status command.",
        "command": "systemctl status example-app --no-pager",
        "transport": "auto",
        "risk": "read-only",
        "execute_mode": "render",
        "tags": [
          "production",
          "web"
        ],
        "status": "active",
        "traffic_role": "primary"
      }
    },
    "deploy": {
      "restart-example-prod": {
        "host": "example-prod",
        "description": "Restart example production service after explicit confirmation.",
        "command": "sudo systemctl restart example-app && curl -fsS http://127.0.0.1:8080/healthz",
        "transport": "auto",
        "risk": "high",
        "execute_mode": "render",
        "confirm": true,
        "tags": [
          "production",
          "restart"
        ],
        "warnings": [
          "Requires explicit user confirmation before execution."
        ],
        "status": "active",
        "traffic_role": "primary"
      }
    }
  },
  "notes": "Sanitized example sidecar. Replace every host, path, command, and salt before real use. Do not store secrets here."
}
