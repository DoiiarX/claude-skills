def remote_command(script: str) -> str:
    return "bash -lc " + shlex.quote(script)


def run_remote_json(spec: dict[str, Any], prefer: str, script: str, timeout: int, input_text: str | None = None) -> dict[str, Any]:
    command = ssh_command_parts(spec, prefer) + [remote_command(script)]
    try:
        completed = subprocess.run(command, input=input_text, text=True, capture_output=True, timeout=timeout)
    except subprocess.TimeoutExpired as exc:
        raise SystemExit(f"Remote command timed out after {timeout}s") from exc
    if completed.returncode != 0:
        detail = completed.stderr.strip() or completed.stdout.strip() or f"exit {completed.returncode}"
        raise SystemExit(f"Remote command failed: {mask_network_text(mask_secret_text(detail))}")
    try:
        result = json.loads(completed.stdout)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Remote command did not return JSON: {exc}") from exc
    if not isinstance(result, dict):
        raise SystemExit("Remote command returned non-object JSON")
    if result.get("ok") is False:
        raise SystemExit(str(result.get("error", "remote operation failed")))
    return result


def fetch_remote_sidecar(spec: dict[str, Any], prefer: str, remote_sidecar: str | None, timeout: int) -> tuple[str, dict[str, Any]]:
    py = r'''
import json, pathlib, subprocess, sys
raw = sys.argv[1]
path = raw
if not path:
    found = None
    for cmd in (["server-md", "locate", "--json"], [str(pathlib.Path.home()/".local/bin/server-md"), "locate", "--json"]):
        try:
            p = subprocess.run(cmd, text=True, capture_output=True, timeout=10)
        except Exception:
            continue
        if p.returncode == 0:
            try:
                data = json.loads(p.stdout)
                found = data.get("sidecar") or data.get("sidecar_path")
            except Exception:
                found = None
        if found:
            break
    if not found:
        print(json.dumps({"ok": False, "error": "remote sidecar not found; pass --remote-sidecar"}))
        raise SystemExit(0)
    path = found
p = pathlib.Path(path).expanduser()
if p.exists():
    data = json.loads(p.read_text(encoding="utf-8"))
else:
    data = {"version": 1, "servers": {}, "resources": {}, "shortcuts": {}}
print(json.dumps({"ok": True, "sidecar": str(p), "data": data}, ensure_ascii=False, separators=(",", ":")))
'''
    script = "python3 -c " + shlex.quote(py) + " " + shlex.quote(remote_sidecar or "")
    result = run_remote_json(spec, prefer, script, timeout)
    data = result.get("data")
    if not isinstance(data, dict):
        raise SystemExit("Remote sidecar data must be an object")
    data.setdefault("servers", {})
    data.setdefault("resources", {})
    data.setdefault("shortcuts", {})
    return str(result.get("sidecar", remote_sidecar or "")), data


def write_remote_sidecar(spec: dict[str, Any], prefer: str, remote_sidecar: str, data: dict[str, Any], dry_run: bool, timeout: int) -> dict[str, Any]:
    py = r'''
import json, os, pathlib, sys
path = pathlib.Path(sys.argv[1]).expanduser()
dry_run = sys.argv[2] == "1"
data = json.load(sys.stdin)
result = {"ok": True, "path": str(path), "dry_run": dry_run, "backup": None, "wrote": False}
if dry_run:
    result["would_write"] = True
    print(json.dumps(result, ensure_ascii=False, separators=(",", ":")))
    raise SystemExit(0)
path.parent.mkdir(parents=True, exist_ok=True)
if path.exists():
    backup = path.with_name(path.name + ".bak")
    backup.write_bytes(path.read_bytes())
    result["backup"] = str(backup)
tmp = path.with_name(f".{path.name}.tmp.{os.getpid()}")
payload = json.dumps(data, ensure_ascii=False, indent=2) + "\n"
try:
    with tmp.open("w", encoding="utf-8") as fh:
        fh.write(payload)
        fh.flush()
        os.fsync(fh.fileno())
    os.replace(tmp, path)
    result["wrote"] = True
finally:
    if tmp.exists():
        try:
            tmp.unlink()
        except OSError:
            pass
print(json.dumps(result, ensure_ascii=False, separators=(",", ":")))
'''
    script = "python3 -c " + shlex.quote(py) + " " + shlex.quote(remote_sidecar) + " " + ("1" if dry_run else "0")
    return run_remote_json(spec, prefer, script, timeout, input_text=json.dumps(data, ensure_ascii=False))


def sync_slice_counts(slice_data: dict[str, Any]) -> dict[str, int]:
    shortcuts = slice_data.get("shortcuts", {})
    shortcut_count = sum(len(v) for v in shortcuts.values() if isinstance(v, dict)) if isinstance(shortcuts, dict) else 0
    return {
        "servers": len(slice_data.get("servers", {}) if isinstance(slice_data.get("servers"), dict) else {}),
        "resources": len(slice_data.get("resources", {}) if isinstance(slice_data.get("resources"), dict) else {}),
        "shortcuts": shortcut_count,
    }


def sync_target_report(args: argparse.Namespace, local_data: dict[str, Any], target: dict[str, Any], scopes: set[str]) -> dict[str, Any]:
    remote_sidecar, remote_data = fetch_remote_sidecar(target["server"], args.prefer, args.remote_sidecar, args.timeout)
    local_slice = extract_server_slice(local_data, target["name"], scopes, args.tag, args.max_depth)
    remote_slice = extract_server_slice(remote_data, target["name"], scopes, args.tag, args.max_depth)
    return {
        "requested": target["requested"],
        "server": target["name"],
        "remote_sidecar": remote_sidecar,
        "local_slice_hash": stable_hash(local_slice),
        "remote_slice_hash": stable_hash(remote_slice),
        "same": stable_hash(local_slice) == stable_hash(remote_slice),
        "local_counts": sync_slice_counts(local_slice),
        "remote_counts": sync_slice_counts(remote_slice),
        "_remote_data": remote_data,
        "_local_slice": local_slice,
        "_remote_slice": remote_slice,
    }


def strip_internal_sync_report(report: dict[str, Any]) -> dict[str, Any]:
    return {k: v for k, v in report.items() if not k.startswith("_")}


def validate_sync_args(args: argparse.Namespace) -> set[str]:
    if args.max_depth != 1:
        raise SystemExit("server-md sync currently supports --max-depth 1 only.")
    if args.remote_sidecar and len(args.server) != 1:
        raise SystemExit("--remote-sidecar can only be used with one --server target.")
    return parse_sync_scopes(args.scope)


