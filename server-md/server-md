#!/usr/bin/env python3
"""Agent-friendly CLI for locating and maintaining personal SERVER.md files."""

from __future__ import annotations

import argparse
import datetime as _dt
import difflib
import hashlib
import json
import os
import platform
import re
import secrets
import shlex
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

REVEAL_ALL = False
REVEAL_SELECTORS: set[str] = set()
MASK_SALT: str | None = None


SECRET_PATTERNS = [
    re.compile(r"Bearer\s+[A-Za-z0-9._~+/=-]{20,}", re.I),
    re.compile(r"(TOKEN|SECRET|PASSWORD|PRIVATE_KEY|CLIENT_SECRET|API_KEY|AUTHORIZATION|ADMIN_TOKEN|API_TOKEN)\s*=\s*[^\s#]+", re.I),
    re.compile(r"nodekey:[A-Za-z0-9._~+/=-]+", re.I),
    re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----"),
]

SENSITIVE_KEY_PARTS = [
    "token", "secret", "password", "privatekey", "private_key", "clientsecret",
    "client_secret", "apikey", "api_key", "authorization", "auth", "nodekey",
]

SENSITIVE_NETWORK_KEYS = {
    "public_ip", "tailnet_ip", "magic_dns", "public_host", "host", "hostname",
    "target_host", "command",
}

SENSITIVE_NETWORK_TEXT_KEYS = {"output", "stdout", "stderr"}

MASK_TYPE_ALIASES = {
    "SECRET": "SECRET",
    "TOKEN": "SECRET",
    "OPENAIKEY": "OPENAIKEY",
    "OPENAI_KEY": "OPENAIKEY",
    "HOST": "HOST",
    "IP": "IP",
    "SSH_KEY": "SSH_KEY",
    "SSH_FINGERPRINT": "SSH_KEY",
    "COMMAND": "COMMAND",
}

NETWORK_PATTERNS = [
    ("SSH_KEY", re.compile(r"SHA256:[A-Za-z0-9+/=]{16,}")),
    ("SSH_KEY", re.compile(r"\bMD5:(?:[0-9a-f]{2}:){15}[0-9a-f]{2}\b", re.I)),
    ("IP", re.compile(r"\b(?:\d{1,3}\.){3}\d{1,3}\b")),
    ("HOST", re.compile(r"\b[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?){2,}\b", re.I)),
]

OPENAI_KEY_PATTERN = re.compile(r"\bsk-[A-Za-z0-9_-]{8,}\b")

def is_sensitive_key(key: str) -> bool:
    normalized = re.sub(r"[^a-z0-9]", "", key.lower())
    return any(part.replace("_", "") in normalized for part in SENSITIVE_KEY_PARTS)


def canonical_mask_type(mask_type: str) -> str:
    normalized = re.sub(r"[^A-Z0-9_]", "_", mask_type.upper()).strip("_")
    return MASK_TYPE_ALIASES.get(normalized, normalized or "SECRET")


def mask_salt_path() -> Path:
    override = os.environ.get("SERVER_MD_MASK_SALT_FILE")
    if override:
        return Path(override).expanduser()
    return Path(__file__).resolve().parent / ".server-md-mask-salt"


def get_mask_salt() -> str:
    global MASK_SALT
    if MASK_SALT:
        return MASK_SALT
    path = mask_salt_path()
    if path.exists():
        MASK_SALT = path.read_text(encoding="utf-8").strip()
    if not MASK_SALT:
        MASK_SALT = secrets.token_hex(32)
        try:
            path.write_text(MASK_SALT + "\n", encoding="utf-8")
            try:
                path.chmod(0o600)
            except OSError:
                pass
        except OSError:
            # If the installed skill directory is read-only, keep a process-local salt.
            pass
    return MASK_SALT


def mask_token(mask_type: str, value: str) -> str:
    kind = canonical_mask_type(mask_type)
    digest = hashlib.sha256((get_mask_salt() + "\0" + kind + "\0" + value).encode("utf-8", errors="ignore")).hexdigest()[:10]
    token = f"__MASKED_{kind}_{digest}__"
    if REVEAL_ALL or kind in REVEAL_SELECTORS or token in REVEAL_SELECTORS:
        return value
    return token


def mask_scalar(value: str, mask_type: str = "SECRET") -> str:
    return mask_token(mask_type, value)


def mask_network_value(value: str, mask_type: str | None = None) -> str:
    if not value:
        return value
    kind = mask_type
    if not kind:
        if re.fullmatch(r"(?:\d{1,3}\.){3}\d{1,3}", value):
            kind = "IP"
        elif "." in value and re.fullmatch(r"[A-Za-z0-9._-]+", value):
            kind = "HOST"
        else:
            kind = "COMMAND"
    return mask_token(kind, value)


def mask_network_text(text: str) -> str:
    for kind, pattern in NETWORK_PATTERNS:
        text = pattern.sub(lambda m, k=kind: mask_network_value(m.group(0), k), text)
    return text


def is_sensitive_network_key(key: str) -> bool:
    normalized = re.sub(r"[^a-z0-9_]", "_", key.lower()).strip("_")
    return normalized in SENSITIVE_NETWORK_KEYS or normalized.endswith("_ip") or normalized.endswith("_host")


def mask_secret_text(text: str) -> str:
    text = OPENAI_KEY_PATTERN.sub(lambda m: mask_token("OPENAIKEY", m.group(0)), text)
    text = re.sub(
        r"Bearer\s+([A-Za-z0-9._~+/=-]{20,})",
        lambda m: "Bearer " + mask_token("SECRET", m.group(1)),
        text,
        flags=re.I,
    )
    text = re.sub(
        r"((?:TOKEN|SECRET|PASSWORD|PRIVATE_KEY|CLIENT_SECRET|API_KEY|AUTHORIZATION|ADMIN_TOKEN|API_TOKEN)\s*=\s*)([^\s#]+)",
        lambda m: m.group(1) + mask_token("SECRET", m.group(2)),
        text,
        flags=re.I,
    )
    text = re.sub(
        r"nodekey:([A-Za-z0-9._~+/=-]+)",
        lambda m: "nodekey:" + mask_token("SECRET", m.group(1)),
        text,
        flags=re.I,
    )
    return text


def mask_data(data: Any, parent_key: str = "") -> Any:
    if isinstance(data, dict):
        out = {}
        for key, value in data.items():
            if is_sensitive_key(str(key)) and isinstance(value, str):
                out[key] = mask_scalar(value, "SECRET")
            elif is_sensitive_network_key(str(key)) and isinstance(value, str):
                out[key] = mask_network_value(value)
            elif re.sub(r"[^a-z0-9_]", "_", str(key).lower()).strip("_") in SENSITIVE_NETWORK_TEXT_KEYS and isinstance(value, str):
                out[key] = mask_network_text(mask_secret_text(value))
            else:
                out[key] = mask_data(value, str(key))
        return out
    if isinstance(data, list):
        return [mask_data(item, parent_key) for item in data]
    if isinstance(data, str):
        text = mask_secret_text(data)
        if is_sensitive_network_key(parent_key):
            text = mask_network_text(text)
        return text
    return data


def emit(data: Any, as_json: bool) -> None:
    data = mask_data(data)
    if as_json:
        print(json.dumps(data, ensure_ascii=False, separators=(",", ":")))
        return
    if isinstance(data, str):
        print(data)
    elif isinstance(data, list):
        for item in data:
            if isinstance(item, dict):
                print("\t".join(f"{k}={v}" for k, v in item.items()))
            else:
                print(item)
    elif isinstance(data, dict):
        for k, v in data.items():
            if isinstance(v, (dict, list)):
                print(f"{k}={json.dumps(v, ensure_ascii=False, separators=(',', ':'))}")
            else:
                print(f"{k}={v}")


def is_wsl() -> bool:
    try:
        text = Path("/proc/version").read_text(encoding="utf-8", errors="ignore").lower()
    except OSError:
        text = ""
    return "microsoft" in text or "wsl" in text


def detect_env() -> dict[str, Any]:
    system = platform.system()
    home = str(Path.home())
    env_type = "linux"
    if system == "Windows":
        env_type = "windows"
    elif is_wsl():
        env_type = "wsl"
    elif os.geteuid() == 0 if hasattr(os, "geteuid") else False:
        env_type = "linux-root-or-server"
    return {
        "environment": env_type,
        "system": system,
        "release": platform.release(),
        "home": home,
        "cwd": str(Path.cwd()),
        "is_wsl": is_wsl(),
    }


def sidecar_path_for(server_md: Path) -> Path:
    return server_md.with_name("server-md.json")


def load_sidecar_for(server_md: Path) -> dict[str, Any] | None:
    sidecar = sidecar_path_for(server_md)
    if not sidecar.exists():
        return None
    try:
        data = json.loads(sidecar.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        return {"_error": f"invalid json: {exc}", "path": str(sidecar)}
    if isinstance(data, dict):
        data.setdefault("path", str(sidecar))
        return data
    return {"_error": "sidecar root must be an object", "path": str(sidecar)}


def resolve_sidecar_path(raw: str | None = None) -> Path:
    if raw:
        return Path(raw).expanduser()
    candidates = [classify_file(p) for p in candidate_paths()]
    canonical = choose_canonical(candidates)
    if canonical:
        sidecar = canonical.get("sidecar_path")
        if sidecar:
            return Path(str(sidecar)).expanduser()
    return sidecar_path_for(Path.home() / "SERVER.md")


def load_sidecar_path(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {
            "version": 1,
            "role": "canonical",
            "priority": 100,
            "markdown": "SERVER.md",
            "inventory": "~/.server-md/inventory.json",
            "servers": {},
            "resources": {},
            "shortcuts": {},
            "execution": {"default_mode": "render", "log": "~/.server-md/ops.jsonl", "confirm_salt": secrets.token_hex(16)},
        }
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise SystemExit(f"Invalid sidecar: root must be an object: {path}")
    data.setdefault("servers", {})
    data.setdefault("resources", {})
    data.setdefault("shortcuts", {})
    ensure_execution_config(data)
    return data


def save_sidecar_path(path: Path, data: dict[str, Any], dry_run: bool) -> None:
    if dry_run:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def canonical_json_bytes(value: Any) -> bytes:
    return json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(",", ":")).encode("utf-8")


def stable_hash(value: Any) -> str:
    return hashlib.sha256(canonical_json_bytes(value)).hexdigest()


def atomic_write_json_with_backup(path: Path, data: dict[str, Any], dry_run: bool) -> dict[str, Any]:
    result: dict[str, Any] = {"path": str(path), "dry_run": dry_run, "backup": None, "wrote": False}
    if dry_run:
        result["would_write"] = True
        return result
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.exists():
        backup = path.with_name(path.name + ".bak")
        backup.write_bytes(path.read_bytes())
        result["backup"] = str(backup)
    tmp = path.with_name(f".{path.name}.tmp.{os.getpid()}")
    payload = json.dumps(data, ensure_ascii=False, indent=2) + "\n"
    try:
        with tmp.open("w", encoding="utf-8") as fh:
            fh.write(payload)
            fh.flush()
            os.fsync(fh.fileno())
        os.replace(tmp, path)
        result["wrote"] = True
    finally:
        if tmp.exists():
            try:
                tmp.unlink()
            except OSError:
                pass
    return result


def ensure_execution_config(data: dict[str, Any]) -> dict[str, Any]:
    execution = data.setdefault("execution", {})
    if not isinstance(execution, dict):
        execution = {}
        data["execution"] = execution
    execution.setdefault("default_mode", "render")
    execution.setdefault("log", "~/.server-md/ops.jsonl")
    execution.setdefault("confirm_salt", secrets.token_hex(16))
    return execution


def append_jsonl(path_raw: str, event: dict[str, Any]) -> None:
    path = Path(path_raw).expanduser()
    path.parent.mkdir(parents=True, exist_ok=True)
    event = {"ts": _dt.datetime.now(_dt.timezone.utc).isoformat(), **event}
    path.open("a", encoding="utf-8").write(json.dumps(mask_data(event), ensure_ascii=False) + "\n")


def shortcut_requires_confirmation(spec: dict[str, Any]) -> bool:
    return bool(spec.get("confirm")) or str(spec.get("risk", "read-only")) in {"medium", "high"}


def parse_key_values(values: list[str] | None, label: str) -> dict[str, str]:
    parsed: dict[str, str] = {}
    for raw in values or []:
        if "=" not in raw:
            raise SystemExit(f"Invalid {label}: {raw!r}. Expected key=value.")
        key, value = raw.split("=", 1)
        if not re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", key):
            raise SystemExit(f"Invalid {label} key: {key!r}. Use letters, digits, and underscore; do not start with a digit.")
        if len(value) > 512 or re.search(r"[\x00-\x1f\x7f]", value):
            raise SystemExit(f"Invalid {label} value for {key!r}: control characters or overly long values are not allowed.")
        if not re.fullmatch(r"[A-Za-z0-9_.:@%+=,/-]*", value):
            raise SystemExit(f"Unsafe {label} value for {key!r}. Allowed characters: letters digits _ . : @ % + = , / -")
        parsed[key] = value
    return parsed


def render_shortcut_command(spec: dict[str, Any], arg_values: list[str] | None = None) -> str:
    command = str(spec.get("command", ""))
    params = spec.get("params", {})
    if not isinstance(params, dict):
        params = {}
    values = {str(k): str(v) for k, v in params.items() if v not in (None, "")}
    values.update(parse_key_values(arg_values, "--arg"))
    placeholders = sorted(set(re.findall(r"\{\{([A-Za-z_][A-Za-z0-9_]*)\}\}", command)))
    missing = [key for key in placeholders if key not in values]
    if missing:
        raise SystemExit(f"Missing shortcut args: {', '.join(missing)}. Pass --arg key=value or set defaults with shortcut add --param key=value.")
    for key in placeholders:
        command = command.replace("{{" + key + "}}", values[key])
    return command


def confirmation_code_for_step(salt: str, category: str, name: str, command: str, step: int) -> str:
    payload = f"{salt}|{step}|{category}|{name}|{command}"
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:10]


def current_totp_step(period: int = 30) -> int:
    return int(time.time() // period)


def confirmation_code(salt: str, category: str, name: str, command: str, period: int = 30) -> str:
    # TOTP-style short window. Default TOTP period is 30 seconds; this avoids static/date-long bypass codes.
    return confirmation_code_for_step(salt, category, name, command, current_totp_step(period))


def valid_confirmation_codes(salt: str, category: str, name: str, command: str, period: int = 30, skew: int = 1) -> set[str]:
    step = current_totp_step(period)
    return {confirmation_code_for_step(salt, category, name, command, step - offset) for offset in range(skew + 1)}


def command_hash(command: str) -> str:
    return hashlib.sha256(command.encode("utf-8")).hexdigest()[:16]


def flatten_shortcuts(data: dict[str, Any]) -> list[dict[str, Any]]:
    shortcuts = data.get("shortcuts", {})
    if not isinstance(shortcuts, dict):
        return []
    rows: list[dict[str, Any]] = []
    for category, entries in shortcuts.items():
        if not isinstance(entries, dict):
            continue
        for name, spec in entries.items():
            if isinstance(spec, dict):
                rows.append({"category": category, "name": name, **spec})
    return rows


def flatten_servers(data: dict[str, Any]) -> list[dict[str, Any]]:
    servers = data.get("servers", {})
    if not isinstance(servers, dict):
        return []
    rows: list[dict[str, Any]] = []
    for name, spec in servers.items():
        if isinstance(spec, dict):
            rows.append({"name": name, **spec})
    return rows


def flatten_resources(data: dict[str, Any]) -> list[dict[str, Any]]:
    resources = data.get("resources", {})
    if not isinstance(resources, dict):
        return []
    rows: list[dict[str, Any]] = []
    for name, spec in resources.items():
        if isinstance(spec, dict):
            rows.append({"name": name, **spec})
    return rows


def find_server(data: dict[str, Any], name_or_alias: str) -> tuple[str, dict[str, Any]] | tuple[None, None]:
    servers = data.get("servers", {})
    if not isinstance(servers, dict):
        return None, None
    if name_or_alias in servers and isinstance(servers[name_or_alias], dict):
        return name_or_alias, servers[name_or_alias]
    for name, spec in servers.items():
        if not isinstance(spec, dict):
            continue
        aliases = spec.get("aliases", [])
        if isinstance(aliases, list) and name_or_alias in aliases:
            return name, spec
    return None, None


def listify_values(*values: Any) -> list[str]:
    result: list[str] = []
    for value in values:
        if value in (None, ""):
            continue
        if isinstance(value, list):
            result.extend(str(item) for item in value if item not in (None, ""))
        else:
            result.append(str(value))
    return sorted(set(result))


def first_value(spec: dict[str, Any], plural_key: str, singular_key: str, default: str | None = None) -> str | None:
    values = listify_values(spec.get(plural_key), spec.get(singular_key))
    return values[0] if values else default


def canonical_server_ref(data: dict[str, Any], raw: Any) -> str | None:
    if raw in (None, ""):
        return None
    name, _spec = find_server(data, str(raw))
    return name or str(raw)


def shortcut_host_matches(data: dict[str, Any], raw_host: Any, target: str) -> bool:
    host = canonical_server_ref(data, raw_host)
    return host == target


def render_ssh_command(spec: dict[str, Any], prefer: str = "auto") -> str:
    user = first_value(spec, "users", "user", "root")
    target_host = None
    if prefer == "tailnet":
        target_host = spec.get("tailnet_ip") or spec.get("magic_dns")
    elif prefer == "public":
        target_host = spec.get("public_ip") or spec.get("public_host")
    else:
        target_host = spec.get("magic_dns") or spec.get("tailnet_ip") or spec.get("public_ip") or spec.get("public_host")
    if not target_host:
        raise SystemExit("Server has no usable host field; set magic_dns, tailnet_ip, public_ip, or public_host.")
    parts = ["ssh"]
    if spec.get("port"):
        parts += ["-p", str(spec["port"])]
    if spec.get("identity"):
        parts += ["-i", str(spec["identity"])]
    if spec.get("proxy_command"):
        parts += ["-o", f"ProxyCommand={spec['proxy_command']}"]
    if spec.get("ssh_extra") and isinstance(spec["ssh_extra"], list):
        parts += [str(x) for x in spec["ssh_extra"]]
    parts.append(f"{user}@{target_host}")
    return shlex.join(parts)


def ssh_command_parts(spec: dict[str, Any], prefer: str = "auto") -> list[str]:
    return shlex.split(render_ssh_command(spec, prefer))


def sidecar_priority(data: dict[str, Any] | None, role: str) -> int:
    if not data or data.get("_error"):
        return 0
    if "priority" in data:
        try:
            return int(data["priority"])
        except (TypeError, ValueError):
            return 0
    declared_role = str(data.get("role", "")).lower()
    if declared_role in {"canonical", "main", "primary"}:
        return 100
    if declared_role in {"pointer", "guide"}:
        return 10
    if declared_role in {"machine-runbook", "node"}:
        return 30
    return 50 if role == "canonical-candidate" else 0


def candidate_paths() -> list[Path]:
    paths: list[Path] = []
    home = Path.home()
    paths.append(home / "SERVER.md")
    if is_wsl():
        users = Path("/mnt/c/Users")
        if users.exists():
            paths.extend(sorted(users.glob("*/SERVER.md")))
    userprofile = os.environ.get("USERPROFILE")
    if userprofile:
        paths.append(Path(userprofile) / "SERVER.md")
    # Preserve order while removing duplicates.
    seen: set[str] = set()
    unique: list[Path] = []
    for path in paths:
        key = str(path)
        if key not in seen:
            seen.add(key)
            unique.append(path)
    return unique


def classify_file(path: Path) -> dict[str, Any]:
    exists = path.exists()
    role = "missing"
    evidence: list[str] = []
    sidecar = None
    if exists:
        text = path.read_text(encoding="utf-8", errors="ignore")[:3000]
        lowered = text.lower()
        if "主副本" in text or "canonical" in lowered:
            role = "canonical-candidate"
            evidence.append("mentions canonical/main copy")
        elif "引导" in text or "指回" in text or "wsl.localhost" in lowered:
            role = "pointer-file"
            evidence.append("looks like a pointer to another file")
        elif "/root/server.md" in lowered or "运维卡片" in text:
            role = "machine-runbook"
            evidence.append("looks like a per-machine runbook")
        else:
            role = "server-md-candidate"
        sidecar = load_sidecar_for(path)
        if sidecar:
            if sidecar.get("_error"):
                evidence.append(f"sidecar error: {sidecar['_error']}")
            else:
                evidence.append("has server-md.json sidecar")
                if sidecar.get("role"):
                    role = str(sidecar["role"])
    priority = sidecar_priority(sidecar, role)
    return {
        "path": str(path),
        "exists": exists,
        "role": role,
        "priority": priority,
        "sidecar_path": str(sidecar_path_for(path)),
        "sidecar": sidecar,
        "evidence": evidence,
    }


def choose_canonical(candidates: list[dict[str, Any]]) -> dict[str, Any] | None:
    existing = [c for c in candidates if c.get("exists")]
    if not existing:
        return None
    return sorted(existing, key=lambda c: (int(c.get("priority") or 0), c.get("role") == "canonical-candidate"), reverse=True)[0]


def cmd_locate(args: argparse.Namespace) -> None:
    candidates = [classify_file(p) for p in candidate_paths()]
    canonical = choose_canonical(candidates)
    if args.verbose:
        data = {
            "environment": detect_env(),
            "canonical": canonical,
            "candidates": candidates,
            "notes": [
                "server-md.json sidecar priority is authoritative",
                "SERVER.md is informational only; query CLI for facts",
            ],
        }
    else:
        sidecar = canonical.get("sidecar") if canonical else None
        data = {
            "canonical_markdown": canonical.get("path") if canonical else None,
            "sidecar": canonical.get("sidecar_path") if canonical else None,
            "role": canonical.get("role") if canonical else None,
            "priority": canonical.get("priority") if canonical else None,
            "environment_hint": sidecar.get("environment_hint") if isinstance(sidecar, dict) else None,
            "reason": "sidecar priority" if isinstance(sidecar, dict) else "no sidecar found",
            "note": "Use server-md CLI commands to query sidecar data; do not read SERVER.md for facts.",
        }
    emit(data, args.json)


def limit_items(items: list[Any], limit: int = 20, tail: bool = False) -> dict[str, Any]:
    total = len(items)
    if limit <= 0:
        shown = items
    elif tail:
        shown = items[-limit:]
    else:
        shown = items[:limit]
    return {
        "items": shown,
        "limit": limit,
        "tail": tail,
        "total": total,
        "truncated": len(shown) < total,
    }


def filter_tags(items: list[dict[str, Any]], tags: list[str] | None) -> list[dict[str, Any]]:
    if not tags:
        return items
    wanted = set(tags)
    return [item for item in items if wanted & set(item.get("tags", []))]


def filter_items(items: list[dict[str, Any]], query: str | None) -> list[dict[str, Any]]:
    if not query:
        return items
    q = query.lower()
    return [item for item in items if q in json.dumps(item, ensure_ascii=False).lower()]


def filter_state(items: list[dict[str, Any]], status: str | None = None, traffic_role: str | None = None) -> list[dict[str, Any]]:
    if status:
        items = [item for item in items if item.get("status") == status]
    if traffic_role:
        items = [item for item in items if item.get("traffic_role") == traffic_role]
    return items


FIND_TYPE_ALIASES = {
    "shortcut": "shortcut",
    "shortcuts": "shortcut",
    "resource": "resource",
    "resources": "resource",
    "server": "server",
    "servers": "server",
}
DEFAULT_FIND_TYPES = ["shortcut", "resource", "server"]


def parse_find_types(raw: list[str] | None) -> list[str]:
    if not raw:
        return DEFAULT_FIND_TYPES.copy()
    result: list[str] = []
    for item in raw:
        for part in str(item).split(","):
            value = part.strip().lower()
            if not value:
                continue
            canonical = FIND_TYPE_ALIASES.get(value)
            if not canonical:
                valid = ", ".join(DEFAULT_FIND_TYPES)
                raise SystemExit(f"Invalid find type: {part}. Valid types: {valid}.")
            if canonical not in result:
                result.append(canonical)
    return result or DEFAULT_FIND_TYPES.copy()


def apply_common_filters(
    items: list[dict[str, Any]],
    tags: list[str] | None,
    status: str | None,
    traffic_role: str | None,
    query: str | None,
) -> list[dict[str, Any]]:
    items = filter_tags(items, tags)
    items = filter_state(items, status, traffic_role)
    return filter_items(items, query)


FIND_TYPE_ORDER = {"shortcut": 0, "resource": 1, "server": 2}
FIND_STATUS_ORDER = {"active": 0, "staging": 1, "unknown": 2, "deprecated": 3, "retired": 4, "disabled": 5}
FIND_TRAFFIC_ORDER = {"primary": 0, "secondary": 1, "staging": 2, "none": 3}


def sort_find_items(items: list[dict[str, Any]]) -> list[dict[str, Any]]:
    indexed = list(enumerate(items))
    indexed.sort(key=lambda pair: (
        FIND_TYPE_ORDER.get(str(pair[1].get("type", "")), 99),
        FIND_STATUS_ORDER.get(str(pair[1].get("status", "unknown")), 2),
        FIND_TRAFFIC_ORDER.get(str(pair[1].get("traffic_role", "none")), 3),
        pair[0],
    ))
    return [item for _idx, item in indexed]


def run_probe(label: str, command: list[str], timeout: int) -> dict[str, Any]:
    try:
        result = subprocess.run(command, text=True, capture_output=True, timeout=timeout)
        output = (result.stdout + result.stderr).strip()
        return {"label": label, "ok": result.returncode == 0, "returncode": result.returncode, "output": output[-2000:]}
    except Exception as exc:
        return {"label": label, "ok": False, "error": str(exc)}


def cmd_redact_check(args: argparse.Namespace) -> None:
    findings = []
    changed_files: list[str] = []
    for raw in args.paths:
        path = Path(raw).expanduser()
        if path.is_dir():
            files = [
                p for p in path.rglob("*")
                if p.is_file() and ".git" not in p.parts
            ]
        else:
            files = [path]
        for file in files:
            try:
                text = file.read_text(encoding="utf-8", errors="ignore")
            except OSError:
                continue
            masked_text = mask_secret_text(text)
            for lineno, line in enumerate(text.splitlines(), 1):
                for pat in SECRET_PATTERNS:
                    if pat.search(line):
                        findings.append({"file": str(file), "line": lineno, "pattern": pat.pattern, "preview": mask_secret_text(line).strip()})
                        break
            if args.fix and masked_text != text:
                file.write_text(masked_text, encoding="utf-8")
                changed_files.append(str(file))
    data = {"ok": not findings, "findings": findings, "fixed_files": changed_files}
    emit(data, args.json)
    if findings and not args.fix:
        sys.exit(1)


def inventory_path(raw: str | None) -> Path:
    return Path(raw or "~/.server-md/inventory.json").expanduser()


def load_inventory(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {"version": 1, "hosts": {}, "services": {}, "links": []}
    return json.loads(path.read_text(encoding="utf-8"))


def save_inventory(path: Path, data: dict[str, Any], dry_run: bool) -> None:
    if dry_run:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def cmd_inventory_init(args: argparse.Namespace) -> None:
    path = inventory_path(args.inventory)
    if path.exists() and not args.force:
        raise SystemExit(f"Refusing to overwrite existing inventory: {path}. Use --force or --dry-run.")
    data = {"version": 1, "hosts": {}, "services": {}, "links": []}
    save_inventory(path, data, args.dry_run)
    emit({"path": str(path), "dry_run": args.dry_run, "inventory": data}, args.json)


