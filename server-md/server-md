def cmd_server_probe(args: argparse.Namespace) -> None:
    path = resolve_sidecar_path(args.sidecar)
    data = load_sidecar_path(path)
    name, spec = find_server(data, args.name)
    if not spec:
        raise SystemExit(f"Server not found: {args.name}. Try: server-md server list --filter {args.name} --json")
    hosts = []
    for key in ["magic_dns", "tailnet_ip", "public_host", "public_ip"]:
        value = spec.get(key)
        if value:
            hosts.append({"field": key, "host": str(value)})
    probes = []
    for item in hosts:
        host = item["host"]
        if not re.match(r"^[0-9.]+$", host):
            probes.append(run_probe(f"dns:{item['field']}", ["getent", "hosts", host], args.timeout))
        probes.append(run_probe(f"tcp22:{item['field']}", ["bash", "-lc", f"timeout {args.timeout} bash -lc '</dev/tcp/{host}/22'"], args.timeout + 2))
    if args.ssh:
        command = ssh_command_parts(spec, args.prefer)
        command += ["-o", "BatchMode=yes", "-o", f"ConnectTimeout={args.timeout}", "true"]
        probes.append(run_probe("ssh", command, args.timeout + 5))
    summary = []
    if not hosts:
        summary.append("No host fields found; set magic_dns, tailnet_ip, public_host, or public_ip.")
    if any(p["label"].startswith("dns:") and not p.get("ok") for p in probes):
        summary.append("DNS lookup failed for at least one hostname.")
    if hosts and not any(p["label"].startswith("tcp22:") and p.get("ok") for p in probes):
        summary.append("No SSH port connectivity succeeded; check IP reachability, firewall, security group, or tailnet status.")
    if args.ssh and any(p["label"] == "ssh" and not p.get("ok") for p in probes):
        summary.append("SSH handshake failed; check key path/permissions, username, host key, or publickey authorization.")
    emit({"sidecar": str(path), "name": name, "hosts": hosts, "probes": probes, "summary": summary, "ok": not summary}, args.json)


