MERGE_UNION_LIST_FIELDS = {"aliases", "roles", "users", "tags", "warnings", "tips", "constraints"}
SYNC_TOP_LEVEL_KEYS = {"version", "sync", "servers", "resources", "shortcuts"}
VALID_SYNC_SCOPES = {"server", "resources", "shortcuts"}


def parse_sync_scopes(raw: list[str] | None) -> set[str]:
    if not raw:
        return set(VALID_SYNC_SCOPES)
    scopes: set[str] = set()
    for item in raw:
        for part in str(item).split(","):
            value = part.strip().lower()
            if not value:
                continue
            if value == "all":
                scopes.update(VALID_SYNC_SCOPES)
            elif value in VALID_SYNC_SCOPES:
                scopes.add(value)
            else:
                raise SystemExit(f"Invalid sync scope: {part!r}. Use all, server, resources, or shortcuts.")
    return scopes or set(VALID_SYNC_SCOPES)


def resolve_sync_targets(data: dict[str, Any], names: list[str]) -> list[dict[str, Any]]:
    seen: set[str] = set()
    targets: list[dict[str, Any]] = []
    for raw in names:
        name, spec = find_server(data, raw)
        if not spec or not name:
            raise SystemExit(f"Server not found: {raw}. Try: server-md server list --filter {raw} --json")
        if name in seen:
            continue
        seen.add(name)
        targets.append({"requested": raw, "name": name, "server": spec})
    return targets


def tags_match(spec: dict[str, Any], tags: list[str] | None) -> bool:
    if not tags:
        return True
    return bool(set(tags) & set(spec.get("tags", [])))


def extract_server_slice(
    data: dict[str, Any],
    target: str,
    scopes: set[str],
    tags: list[str] | None = None,
    max_depth: int = 1,
) -> dict[str, Any]:
    if max_depth != 1:
        raise SystemExit("server-md sync currently supports --max-depth 1 only.")
    result: dict[str, Any] = {
        "version": 1,
        "sync": {
            "target": target,
            "max_depth": max_depth,
            "scopes": sorted(scopes),
            "tags": tags or [],
            "generated_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
        },
        "servers": {},
        "resources": {},
        "shortcuts": {},
    }
    servers = data.get("servers", {})
    if "server" in scopes and isinstance(servers, dict) and isinstance(servers.get(target), dict):
        result["servers"][target] = json.loads(json.dumps(servers[target]))
    resources = data.get("resources", {})
    if "resources" in scopes and isinstance(resources, dict):
        for name, spec in resources.items():
            if isinstance(spec, dict) and canonical_server_ref(data, spec.get("server")) == target and tags_match(spec, tags):
                item = json.loads(json.dumps(spec))
                item["server"] = target
                result["resources"][name] = item
    shortcuts = data.get("shortcuts", {})
    if "shortcuts" in scopes and isinstance(shortcuts, dict):
        for category, entries in shortcuts.items():
            if not isinstance(entries, dict):
                continue
            selected: dict[str, Any] = {}
            for name, spec in entries.items():
                if isinstance(spec, dict) and shortcut_host_matches(data, spec.get("host"), target) and tags_match(spec, tags):
                    item = json.loads(json.dumps(spec))
                    item["host"] = target
                    selected[name] = item
            if selected:
                result["shortcuts"][category] = selected
    result["sync"]["source_hash"] = stable_hash({"servers": result["servers"], "resources": result["resources"], "shortcuts": result["shortcuts"]})
    return result


def validate_server_slice(slice_data: dict[str, Any], target: str, scopes: set[str]) -> list[str]:
    errors: list[str] = []
    for key in slice_data:
        if key not in SYNC_TOP_LEVEL_KEYS:
            errors.append(f"unexpected top-level key: {key}")
    sync = slice_data.get("sync", {})
    if isinstance(sync, dict) and sync.get("max_depth") not in (None, 1):
        errors.append("sync slice max_depth must be 1")
    servers = slice_data.get("servers", {})
    if isinstance(servers, dict):
        for name in servers:
            if name != target:
                errors.append(f"slice includes non-target server: {name}")
    elif servers not in (None, {}):
        errors.append("slice servers must be an object")
    resources = slice_data.get("resources", {})
    if isinstance(resources, dict):
        for name, spec in resources.items():
            if isinstance(spec, dict):
                if spec.get("server") != target:
                    errors.append(f"resource {name} is not scoped to {target}")
            else:
                errors.append(f"resource {name} must be an object")
    elif resources not in (None, {}):
        errors.append("slice resources must be an object")
    shortcuts = slice_data.get("shortcuts", {})
    if isinstance(shortcuts, dict):
        for category, entries in shortcuts.items():
            if not isinstance(entries, dict):
                errors.append(f"shortcut category {category} must be an object")
                continue
            for name, spec in entries.items():
                if isinstance(spec, dict):
                    if spec.get("host") != target:
                        errors.append(f"shortcut {category}/{name} is not scoped to {target}")
                else:
                    errors.append(f"shortcut {category}/{name} must be an object")
    elif shortcuts not in (None, {}):
        errors.append("slice shortcuts must be an object")
    return errors


def merge_values(local_value: Any, remote_value: Any, path: str) -> tuple[Any, list[str]]:
    if local_value == remote_value:
        return local_value, []
    key = path.rsplit(".", 1)[-1]
    if isinstance(local_value, list) and isinstance(remote_value, list) and key in MERGE_UNION_LIST_FIELDS:
        return sorted(set(str(x) for x in local_value + remote_value)), []
    if isinstance(local_value, dict) and isinstance(remote_value, dict):
        merged = dict(local_value)
        conflicts: list[str] = []
        for k, v in remote_value.items():
            if k not in merged:
                merged[k] = v
            else:
                merged[k], child = merge_values(merged[k], v, f"{path}.{k}")
                conflicts.extend(child)
        return merged, conflicts
    return local_value, [path]


def parse_record_time(spec: dict[str, Any]) -> str | None:
    for key in ["updated_at", "modified_at", "mtime"]:
        value = spec.get(key)
        if value:
            return str(value)
    return None


def resolve_record_conflict(local: Any, remote: Any, conflict: str, label: str) -> tuple[Any, str, list[str]]:
    if local == remote:
        return local, "unchanged", []
    if conflict == "local":
        return local, "kept-local", []
    if conflict == "remote":
        return remote, "updated", []
    if conflict == "newer" and isinstance(local, dict) and isinstance(remote, dict):
        lt = parse_record_time(local)
        rt = parse_record_time(remote)
        if lt and rt:
            return (remote, "updated", []) if rt > lt else (local, "kept-local", [])
        if rt and not lt:
            return remote, "updated", []
        if lt and not rt:
            return local, "kept-local", []
    if conflict == "merge":
        merged, conflicts = merge_values(local, remote, label)
        if not conflicts:
            return merged, "merged", []
        return local, "conflict", conflicts
    return local, "conflict", [label]


def apply_server_slice(
    base: dict[str, Any],
    incoming: dict[str, Any],
    target: str,
    scopes: set[str],
    tags: list[str] | None,
    conflict: str,
) -> tuple[dict[str, Any], dict[str, Any]]:
    errors = validate_server_slice(incoming, target, scopes)
    report: dict[str, Any] = {"added": [], "updated": [], "merged": [], "unchanged": [], "kept_local": [], "conflicts": [], "rejected": errors}
    if errors:
        return base, report
    out = json.loads(json.dumps(base))
    out.setdefault("servers", {})
    out.setdefault("resources", {})
    out.setdefault("shortcuts", {})

    if "server" in scopes:
        incoming_servers = incoming.get("servers", {}) if isinstance(incoming.get("servers", {}), dict) else {}
        if target in incoming_servers:
            servers = out.setdefault("servers", {})
            if target not in servers:
                servers[target] = incoming_servers[target]
                report["added"].append(f"server:{target}")
            else:
                chosen, action, conflicts = resolve_record_conflict(servers[target], incoming_servers[target], conflict, f"server:{target}")
                if conflicts:
                    report["conflicts"].extend(conflicts)
                else:
                    servers[target] = chosen
                    report[{"unchanged": "unchanged", "kept-local": "kept_local"}.get(action, action)].append(f"server:{target}")

    if "resources" in scopes:
        resources = out.setdefault("resources", {})
        incoming_resources = incoming.get("resources", {}) if isinstance(incoming.get("resources", {}), dict) else {}
        for name, spec in incoming_resources.items():
            if not isinstance(spec, dict) or not tags_match(spec, tags):
                continue
            label = f"resource:{name}"
            if name not in resources:
                resources[name] = spec
                report["added"].append(label)
            else:
                chosen, action, conflicts = resolve_record_conflict(resources[name], spec, conflict, label)
                if conflicts:
                    report["conflicts"].extend(conflicts)
                else:
                    resources[name] = chosen
                    report[{"unchanged": "unchanged", "kept-local": "kept_local"}.get(action, action)].append(label)

    if "shortcuts" in scopes:
        shortcuts = out.setdefault("shortcuts", {})
        incoming_shortcuts = incoming.get("shortcuts", {}) if isinstance(incoming.get("shortcuts", {}), dict) else {}
        for category, entries in incoming_shortcuts.items():
            if not isinstance(entries, dict):
                continue
            dest = shortcuts.setdefault(category, {})
            for name, spec in entries.items():
                if not isinstance(spec, dict) or not tags_match(spec, tags):
                    continue
                label = f"shortcut:{category}/{name}"
                if name not in dest:
                    dest[name] = spec
                    report["added"].append(label)
                else:
                    chosen, action, conflicts = resolve_record_conflict(dest[name], spec, conflict, label)
                    if conflicts:
                        report["conflicts"].extend(conflicts)
                    else:
                        dest[name] = chosen
                        report[{"unchanged": "unchanged", "kept-local": "kept_local"}.get(action, action)].append(label)
    return out, report


def report_has_changes(report: dict[str, Any]) -> bool:
    return bool(report.get("added") or report.get("updated") or report.get("merged"))


def report_has_errors(report: dict[str, Any]) -> bool:
    return bool(report.get("conflicts") or report.get("rejected"))


