def main() -> None:
    global REVEAL_SECRETS
    hint = command_hint(sys.argv[1:])
    if hint:
        print(f"server-md: {hint}", file=sys.stderr)
        raise SystemExit(2)
    parser = build_parser()
    args = parser.parse_args()
    REVEAL_SECRETS = bool(getattr(args, "reveal", False))
    args.func(args)


if __name__ == "__main__":
    main()
