#!/usr/bin/env python3
"""Agent-friendly CLI for locating and maintaining personal SERVER.md files."""

from __future__ import annotations

import argparse
import datetime as _dt
import difflib
import hashlib
import json
import os
import platform
import re
import secrets
import shlex
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

REVEAL_SECRETS = False


SECRET_PATTERNS = [
    re.compile(r"Bearer\s+[A-Za-z0-9._~+/=-]{20,}", re.I),
    re.compile(r"(TOKEN|SECRET|PASSWORD|PRIVATE_KEY|CLIENT_SECRET|API_KEY|AUTHORIZATION|ADMIN_TOKEN|API_TOKEN)\s*=\s*[^\s#]+", re.I),
    re.compile(r"nodekey:[A-Za-z0-9._~+/=-]+", re.I),
    re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----"),
]

SENSITIVE_KEY_PARTS = [
    "token", "secret", "password", "privatekey", "private_key", "clientsecret",
    "client_secret", "apikey", "api_key", "authorization", "auth", "nodekey",
]

def is_sensitive_key(key: str) -> bool:
    normalized = re.sub(r"[^a-z0-9]", "", key.lower())
    return any(part.replace("_", "") in normalized for part in SENSITIVE_KEY_PARTS)


def mask_scalar(value: str) -> str:
    if len(value) <= 8:
        return "***"
    return f"{value[:4]}***{value[-4:]}"


def mask_secret_text(text: str) -> str:
    text = re.sub(
        r"Bearer\s+([A-Za-z0-9._~+/=-]{20,})",
        lambda m: "Bearer " + mask_scalar(m.group(1)),
        text,
        flags=re.I,
    )
    text = re.sub(
        r"((?:TOKEN|SECRET|PASSWORD|PRIVATE_KEY|CLIENT_SECRET|API_KEY|AUTHORIZATION|ADMIN_TOKEN|API_TOKEN)\s*=\s*)([^\s#]+)",
        lambda m: m.group(1) + mask_scalar(m.group(2)),
        text,
        flags=re.I,
    )
    text = re.sub(
        r"nodekey:([A-Za-z0-9._~+/=-]+)",
        lambda m: "nodekey:" + mask_scalar(m.group(1)),
        text,
        flags=re.I,
    )
    return text


def mask_data(data: Any, parent_key: str = "") -> Any:
    if REVEAL_SECRETS:
        return data
    if isinstance(data, dict):
        out = {}
        for key, value in data.items():
            if is_sensitive_key(str(key)) and isinstance(value, str):
                out[key] = mask_scalar(value) + " (masked; pass --reveal before the subcommand to show)"
            else:
                out[key] = mask_data(value, str(key))
        return out
    if isinstance(data, list):
        return [mask_data(item, parent_key) for item in data]
    if isinstance(data, str):
        return mask_secret_text(data)
    return data


def emit(data: Any, as_json: bool) -> None:
    data = mask_data(data)
    if as_json:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    if isinstance(data, str):
        print(data)
    elif isinstance(data, list):
        for item in data:
            if isinstance(item, dict):
                print("\t".join(f"{k}={v}" for k, v in item.items()))
            else:
                print(item)
    elif isinstance(data, dict):
        for k, v in data.items():
            if isinstance(v, (dict, list)):
                print(f"{k}={json.dumps(v, ensure_ascii=False)}")
            else:
                print(f"{k}={v}")


def is_wsl() -> bool:
    try:
        text = Path("/proc/version").read_text(encoding="utf-8", errors="ignore").lower()
    except OSError:
        text = ""
    return "microsoft" in text or "wsl" in text


def detect_env() -> dict[str, Any]:
    system = platform.system()
    home = str(Path.home())
    env_type = "linux"
    if system == "Windows":
        env_type = "windows"
    elif is_wsl():
        env_type = "wsl"
    elif os.geteuid() == 0 if hasattr(os, "geteuid") else False:
        env_type = "linux-root-or-server"
    return {
        "environment": env_type,
        "system": system,
        "release": platform.release(),
        "home": home,
        "cwd": str(Path.cwd()),
        "is_wsl": is_wsl(),
    }


def sidecar_path_for(server_md: Path) -> Path:
    return server_md.with_name("server-md.json")


def load_sidecar_for(server_md: Path) -> dict[str, Any] | None:
    sidecar = sidecar_path_for(server_md)
    if not sidecar.exists():
        return None
    try:
        data = json.loads(sidecar.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        return {"_error": f"invalid json: {exc}", "path": str(sidecar)}
    if isinstance(data, dict):
        data.setdefault("path", str(sidecar))
        return data
    return {"_error": "sidecar root must be an object", "path": str(sidecar)}


def resolve_sidecar_path(raw: str | None = None) -> Path:
    if raw:
        return Path(raw).expanduser()
    candidates = [classify_file(p) for p in candidate_paths()]
    canonical = choose_canonical(candidates)
    if canonical:
        sidecar = canonical.get("sidecar_path")
        if sidecar:
            return Path(str(sidecar)).expanduser()
    return sidecar_path_for(Path.home() / "SERVER.md")


def load_sidecar_path(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {
            "version": 1,
            "role": "canonical",
            "priority": 100,
            "markdown": "SERVER.md",
            "inventory": "~/.server-md/inventory.json",
            "servers": {},
            "resources": {},
            "shortcuts": {},
            "execution": {"default_mode": "render", "log": "~/.server-md/ops.jsonl", "confirm_salt": secrets.token_hex(16)},
        }
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise SystemExit(f"Invalid sidecar: root must be an object: {path}")
    data.setdefault("servers", {})
    data.setdefault("resources", {})
    data.setdefault("shortcuts", {})
    ensure_execution_config(data)
    return data


def save_sidecar_path(path: Path, data: dict[str, Any], dry_run: bool) -> None:
    if dry_run:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def ensure_execution_config(data: dict[str, Any]) -> dict[str, Any]:
    execution = data.setdefault("execution", {})
    if not isinstance(execution, dict):
        execution = {}
        data["execution"] = execution
    execution.setdefault("default_mode", "render")
    execution.setdefault("log", "~/.server-md/ops.jsonl")
    execution.setdefault("confirm_salt", secrets.token_hex(16))
    return execution


def append_jsonl(path_raw: str, event: dict[str, Any]) -> None:
    path = Path(path_raw).expanduser()
    path.parent.mkdir(parents=True, exist_ok=True)
    event = {"ts": _dt.datetime.now(_dt.timezone.utc).isoformat(), **event}
    path.open("a", encoding="utf-8").write(json.dumps(mask_data(event), ensure_ascii=False) + "\n")


def shortcut_requires_confirmation(spec: dict[str, Any]) -> bool:
    return bool(spec.get("confirm")) or str(spec.get("risk", "read-only")) in {"medium", "high"}


def confirmation_code_for_step(salt: str, category: str, name: str, command: str, step: int) -> str:
    payload = f"{salt}|{step}|{category}|{name}|{command}"
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:10]


def current_totp_step(period: int = 30) -> int:
    return int(time.time() // period)


def confirmation_code(salt: str, category: str, name: str, command: str, period: int = 30) -> str:
    # TOTP-style short window. Default TOTP period is 30 seconds; this avoids static/date-long bypass codes.
    return confirmation_code_for_step(salt, category, name, command, current_totp_step(period))


def valid_confirmation_codes(salt: str, category: str, name: str, command: str, period: int = 30, skew: int = 1) -> set[str]:
    step = current_totp_step(period)
    return {confirmation_code_for_step(salt, category, name, command, step - offset) for offset in range(skew + 1)}


def command_hash(command: str) -> str:
    return hashlib.sha256(command.encode("utf-8")).hexdigest()[:16]


def flatten_shortcuts(data: dict[str, Any]) -> list[dict[str, Any]]:
    shortcuts = data.get("shortcuts", {})
    if not isinstance(shortcuts, dict):
        return []
    rows: list[dict[str, Any]] = []
    for category, entries in shortcuts.items():
        if not isinstance(entries, dict):
            continue
        for name, spec in entries.items():
            if isinstance(spec, dict):
                rows.append({"category": category, "name": name, **spec})
    return rows


def flatten_servers(data: dict[str, Any]) -> list[dict[str, Any]]:
    servers = data.get("servers", {})
    if not isinstance(servers, dict):
        return []
    rows: list[dict[str, Any]] = []
    for name, spec in servers.items():
        if isinstance(spec, dict):
            rows.append({"name": name, **spec})
    return rows


def flatten_resources(data: dict[str, Any]) -> list[dict[str, Any]]:
    resources = data.get("resources", {})
    if not isinstance(resources, dict):
        return []
    rows: list[dict[str, Any]] = []
    for name, spec in resources.items():
        if isinstance(spec, dict):
            rows.append({"name": name, **spec})
    return rows


def find_server(data: dict[str, Any], name_or_alias: str) -> tuple[str, dict[str, Any]] | tuple[None, None]:
    servers = data.get("servers", {})
    if not isinstance(servers, dict):
        return None, None
    if name_or_alias in servers and isinstance(servers[name_or_alias], dict):
        return name_or_alias, servers[name_or_alias]
    for name, spec in servers.items():
        if not isinstance(spec, dict):
            continue
        aliases = spec.get("aliases", [])
        if isinstance(aliases, list) and name_or_alias in aliases:
            return name, spec
    return None, None


def render_ssh_command(spec: dict[str, Any], prefer: str = "auto") -> str:
    user = spec.get("user") or "root"
    target_host = None
    if prefer == "tailnet":
        target_host = spec.get("tailnet_ip") or spec.get("magic_dns")
    elif prefer == "public":
        target_host = spec.get("public_ip") or spec.get("public_host")
    else:
        target_host = spec.get("magic_dns") or spec.get("tailnet_ip") or spec.get("public_ip") or spec.get("public_host")
    if not target_host:
        raise SystemExit("Server has no usable host field; set magic_dns, tailnet_ip, public_ip, or public_host.")
    parts = ["ssh"]
    if spec.get("port"):
        parts += ["-p", str(spec["port"])]
    if spec.get("identity"):
        parts += ["-i", str(spec["identity"])]
    if spec.get("proxy_command"):
        parts += ["-o", f"ProxyCommand={spec['proxy_command']}"]
    if spec.get("ssh_extra") and isinstance(spec["ssh_extra"], list):
        parts += [str(x) for x in spec["ssh_extra"]]
    parts.append(f"{user}@{target_host}")
    return shlex.join(parts)


def ssh_command_parts(spec: dict[str, Any], prefer: str = "auto") -> list[str]:
    return shlex.split(render_ssh_command(spec, prefer))


def sidecar_priority(data: dict[str, Any] | None, role: str) -> int:
    if not data or data.get("_error"):
        return 0
    if "priority" in data:
        try:
            return int(data["priority"])
        except (TypeError, ValueError):
            return 0
    declared_role = str(data.get("role", "")).lower()
    if declared_role in {"canonical", "main", "primary"}:
        return 100
    if declared_role in {"pointer", "guide"}:
        return 10
    if declared_role in {"machine-runbook", "node"}:
        return 30
    return 50 if role == "canonical-candidate" else 0


def candidate_paths() -> list[Path]:
    paths: list[Path] = []
    home = Path.home()
    paths.append(home / "SERVER.md")
    if is_wsl():
        users = Path("/mnt/c/Users")
        if users.exists():
            paths.extend(sorted(users.glob("*/SERVER.md")))
    userprofile = os.environ.get("USERPROFILE")
    if userprofile:
        paths.append(Path(userprofile) / "SERVER.md")
    # Preserve order while removing duplicates.
    seen: set[str] = set()
    unique: list[Path] = []
    for path in paths:
        key = str(path)
        if key not in seen:
            seen.add(key)
            unique.append(path)
    return unique


def classify_file(path: Path) -> dict[str, Any]:
    exists = path.exists()
    role = "missing"
    evidence: list[str] = []
    sidecar = None
    if exists:
        text = path.read_text(encoding="utf-8", errors="ignore")[:3000]
        lowered = text.lower()
        if "主副本" in text or "canonical" in lowered:
            role = "canonical-candidate"
            evidence.append("mentions canonical/main copy")
        elif "引导" in text or "指回" in text or "wsl.localhost" in lowered:
            role = "pointer-file"
            evidence.append("looks like a pointer to another file")
        elif "/root/server.md" in lowered or "运维卡片" in text:
            role = "machine-runbook"
            evidence.append("looks like a per-machine runbook")
        else:
            role = "server-md-candidate"
        sidecar = load_sidecar_for(path)
        if sidecar:
            if sidecar.get("_error"):
                evidence.append(f"sidecar error: {sidecar['_error']}")
            else:
                evidence.append("has server-md.json sidecar")
                if sidecar.get("role"):
                    role = str(sidecar["role"])
    priority = sidecar_priority(sidecar, role)
    return {
        "path": str(path),
        "exists": exists,
        "role": role,
        "priority": priority,
        "sidecar_path": str(sidecar_path_for(path)),
        "sidecar": sidecar,
        "evidence": evidence,
    }


def choose_canonical(candidates: list[dict[str, Any]]) -> dict[str, Any] | None:
    existing = [c for c in candidates if c.get("exists")]
    if not existing:
        return None
    return sorted(existing, key=lambda c: (int(c.get("priority") or 0), c.get("role") == "canonical-candidate"), reverse=True)[0]


def cmd_locate(args: argparse.Namespace) -> None:
    candidates = [classify_file(p) for p in candidate_paths()]
    canonical = choose_canonical(candidates)
    if args.verbose:
        data = {
            "environment": detect_env(),
            "canonical": canonical,
            "candidates": candidates,
            "notes": [
                "server-md.json sidecar priority is authoritative",
                "SERVER.md is informational only; query CLI for facts",
            ],
        }
    else:
        sidecar = canonical.get("sidecar") if canonical else None
        data = {
            "canonical_markdown": canonical.get("path") if canonical else None,
            "sidecar": canonical.get("sidecar_path") if canonical else None,
            "role": canonical.get("role") if canonical else None,
            "priority": canonical.get("priority") if canonical else None,
            "environment_hint": sidecar.get("environment_hint") if isinstance(sidecar, dict) else None,
            "reason": "sidecar priority" if isinstance(sidecar, dict) else "no sidecar found",
            "note": "Use server-md CLI commands to query sidecar data; do not read SERVER.md for facts.",
        }
    emit(data, args.json)


def limit_items(items: list[Any], limit: int = 20, tail: bool = False) -> dict[str, Any]:
    total = len(items)
    if limit <= 0:
        shown = items
    elif tail:
        shown = items[-limit:]
    else:
        shown = items[:limit]
    return {
        "items": shown,
        "limit": limit,
        "tail": tail,
        "total": total,
        "truncated": len(shown) < total,
    }


def filter_items(items: list[dict[str, Any]], query: str | None) -> list[dict[str, Any]]:
    if not query:
        return items
    q = query.lower()
    return [item for item in items if q in json.dumps(item, ensure_ascii=False).lower()]


def filter_state(items: list[dict[str, Any]], status: str | None = None, traffic_role: str | None = None) -> list[dict[str, Any]]:
    if status:
        items = [item for item in items if item.get("status") == status]
    if traffic_role:
        items = [item for item in items if item.get("traffic_role") == traffic_role]
    return items


def run_probe(label: str, command: list[str], timeout: int) -> dict[str, Any]:
    try:
        result = subprocess.run(command, text=True, capture_output=True, timeout=timeout)
        output = (result.stdout + result.stderr).strip()
        return {"label": label, "command": command, "ok": result.returncode == 0, "returncode": result.returncode, "output": output[-2000:]}
    except Exception as exc:
        return {"label": label, "command": command, "ok": False, "error": str(exc)}


def cmd_redact_check(args: argparse.Namespace) -> None:
    findings = []
    changed_files: list[str] = []
    for raw in args.paths:
        path = Path(raw).expanduser()
        if path.is_dir():
            files = [
                p for p in path.rglob("*")
                if p.is_file() and ".git" not in p.parts
            ]
        else:
            files = [path]
        for file in files:
            try:
                text = file.read_text(encoding="utf-8", errors="ignore")
            except OSError:
                continue
            masked_text = mask_secret_text(text)
            for lineno, line in enumerate(text.splitlines(), 1):
                for pat in SECRET_PATTERNS:
                    if pat.search(line):
                        findings.append({"file": str(file), "line": lineno, "pattern": pat.pattern, "preview": mask_secret_text(line).strip()})
                        break
            if args.fix and masked_text != text:
                file.write_text(masked_text, encoding="utf-8")
                changed_files.append(str(file))
    data = {"ok": not findings, "findings": findings, "fixed_files": changed_files}
    emit(data, args.json)
    if findings and not args.fix:
        sys.exit(1)


def inventory_path(raw: str | None) -> Path:
    return Path(raw or "~/.server-md/inventory.json").expanduser()


def load_inventory(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {"version": 1, "hosts": {}, "services": {}, "links": []}
    return json.loads(path.read_text(encoding="utf-8"))


def save_inventory(path: Path, data: dict[str, Any], dry_run: bool) -> None:
    if dry_run:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def cmd_inventory_init(args: argparse.Namespace) -> None:
    path = inventory_path(args.inventory)
    if path.exists() and not args.force:
        raise SystemExit(f"Refusing to overwrite existing inventory: {path}. Use --force or --dry-run.")
    data = {"version": 1, "hosts": {}, "services": {}, "links": []}
    save_inventory(path, data, args.dry_run)
    emit({"path": str(path), "dry_run": args.dry_run, "inventory": data}, args.json)


def cmd_inventory_list(args: argparse.Namespace) -> None:
    path = inventory_path(args.inventory)
    data = load_inventory(path)
    if args.kind == "hosts":
        result = [{"name": name, **value} for name, value in data.get("hosts", {}).items()]
    elif args.kind == "services":
        result = [{"name": name, **value} for name, value in data.get("services", {}).items()]
    else:
        result = [{"kind": "host", "name": name, **value} for name, value in data.get("hosts", {}).items()]
        result += [{"kind": "service", "name": name, **value} for name, value in data.get("services", {}).items()]
    result = filter_items(result, args.filter)
    if args.tag:
        wanted = set(args.tag)
        result = [item for item in result if (wanted & set(item.get("tags", [])))]
    if args.host:
        result = [item for item in result if item.get("host") == args.host or item.get("name") == args.host]
    result = filter_state(result, args.status, args.traffic_role)
    emit({"inventory": str(path), "kind": args.kind, "results": limit_items(result, args.limit, args.tail)}, args.json)


def cmd_host_set(args: argparse.Namespace) -> None:
    path = inventory_path(args.inventory)
    data = load_inventory(path)
    hosts = data.setdefault("hosts", {})
    current = hosts.setdefault(args.name, {})
    fields = {
        "role": args.role,
        "os": args.os,
        "user": args.user,
        "public_ip": args.public_ip,
        "tailnet_ip": args.tailnet_ip,
        "magic_dns": args.magic_dns,
        "ssh": args.ssh,
        "risk": args.risk,
        "notes_file": args.notes_file,
        "status": args.status,
        "traffic_role": args.traffic_role,
    }
    for key, value in fields.items():
        if value not in (None, ""):
            current[key] = value
    if args.tag:
        current["tags"] = sorted(set(current.get("tags", []) + args.tag))
    save_inventory(path, data, args.dry_run)
    emit({"path": str(path), "dry_run": args.dry_run, "host": {"name": args.name, **current}}, args.json)


def cmd_service_set(args: argparse.Namespace) -> None:
    path = inventory_path(args.inventory)
    data = load_inventory(path)
    services = data.setdefault("services", {})
    current = services.setdefault(args.name, {})
    fields = {
        "host": args.host,
        "kind": args.kind,
        "public_url": args.public_url,
        "local_url": args.local_url,
        "unit": args.unit,
        "config_path": args.config_path,
        "data_path": args.data_path,
        "healthcheck": args.healthcheck,
        "risk": args.risk,
        "notes_file": args.notes_file,
        "status": args.status,
        "traffic_role": args.traffic_role,
    }
    for key, value in fields.items():
        if value not in (None, ""):
            current[key] = value
    if args.tag:
        current["tags"] = sorted(set(current.get("tags", []) + args.tag))
    save_inventory(path, data, args.dry_run)
    emit({"path": str(path), "dry_run": args.dry_run, "service": {"name": args.name, **current}}, args.json)


def cmd_inventory_validate(args: argparse.Namespace) -> None:
    path = inventory_path(args.inventory)
    data = load_inventory(path)
    errors = []
    if not isinstance(data.get("hosts", {}), dict):
        errors.append("hosts must be an object")
    if not isinstance(data.get("services", {}), dict):
        errors.append("services must be an object")
    hosts = data.get("hosts", {}) if isinstance(data.get("hosts", {}), dict) else {}
    for name, svc in (data.get("services", {}) or {}).items():
        host = svc.get("host") if isinstance(svc, dict) else None
        if host and host not in hosts:
            errors.append(f"service {name!r} references unknown host {host!r}")
    result = {"ok": not errors, "path": str(path), "errors": errors}
    emit(result, args.json)
    if errors:
        sys.exit(1)
def cmd_server_brief(args: argparse.Namespace) -> None:
    path = resolve_sidecar_path(args.sidecar)
    data = load_sidecar_path(path)
    name, spec = find_server(data, args.name)
    if not spec:
        raise SystemExit(f"Server not found: {args.name}. Try: server-md server list --filter {args.name} --json")
    resources = flatten_resources(data)
    shortcuts = flatten_shortcuts(data)
    if args.tag:
        wanted = set(args.tag)
        resources = [r for r in resources if (wanted & set(r.get("tags", [])))]
        shortcuts = [r for r in shortcuts if (wanted & set(r.get("tags", [])))]
    resources = [r for r in resources if r.get("server") in {args.name, name}]
    shortcuts = [r for r in shortcuts if r.get("host") in {args.name, name}]
    if args.status:
        resources = [r for r in resources if r.get("status") == args.status]
        shortcuts = [r for r in shortcuts if r.get("status") == args.status]
    if args.traffic_role:
        resources = [r for r in resources if r.get("traffic_role") == args.traffic_role]
        shortcuts = [r for r in shortcuts if r.get("traffic_role") == args.traffic_role]
    if args.filter:
        resources = filter_items(resources, args.filter)
        shortcuts = filter_items(shortcuts, args.filter)
    emit({
        "sidecar": str(path),
        "name": name,
        "server": spec,
        "resources": limit_items(resources, args.limit, args.tail),
        "shortcuts": limit_items(shortcuts, args.limit, args.tail),
