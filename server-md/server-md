        info = sync_target_report(args, next_data, target, scopes)
        merged, report = apply_server_slice(next_data, info["_remote_slice"], target["name"], scopes, args.tag, args.conflict)
        reports.append({**strip_internal_sync_report(info), "changes": report, "would_write_local": report_has_changes(report)})
        if report_has_errors(report):
            emit({"operation": "pull", "local_sidecar": str(path), "targets": reports, "ok": False}, args.json)
            raise SystemExit(1)
        next_data = merged
    write = atomic_write_json_with_backup(path, next_data, args.dry_run) if any(r.get("would_write_local") for r in reports) else {"wrote": False, "dry_run": args.dry_run}
    emit({"operation": "pull", "local_sidecar": str(path), "write": write, "targets": reports, "ok": True}, args.json)


def cmd_sync_push(args: argparse.Namespace) -> None:
    scopes = validate_sync_args(args)
    path = resolve_sidecar_path(args.sidecar)
    local_data = load_sidecar_path(path)
    targets = resolve_sync_targets(local_data, args.server)
    reports = []
    for target in targets:
        info = sync_target_report(args, local_data, target, scopes)
        remote_next, report = apply_server_slice(info["_remote_data"], info["_local_slice"], target["name"], scopes, args.tag, args.conflict)
        item = {**strip_internal_sync_report(info), "changes": report, "would_write_remote": report_has_changes(report)}
        if report_has_errors(report):
            reports.append(item)
            emit({"operation": "push", "local_sidecar": str(path), "targets": reports, "ok": False}, args.json)
            raise SystemExit(1)
        if report_has_changes(report):
            item["remote_write"] = write_remote_sidecar(target["server"], args.prefer, info["remote_sidecar"], remote_next, args.dry_run, args.timeout)
        reports.append(item)
    emit({"operation": "push", "local_sidecar": str(path), "targets": reports, "ok": True}, args.json)


def cmd_sync_bidir(args: argparse.Namespace) -> None:
    scopes = validate_sync_args(args)
    path = resolve_sidecar_path(args.sidecar)
    local_data = load_sidecar_path(path)
    targets = resolve_sync_targets(local_data, args.server)
    reports = []
    local_next = local_data
    remote_writes: list[tuple[dict[str, Any], str, dict[str, Any], dict[str, Any]]] = []
    for target in targets:
        info = sync_target_report(args, local_next, target, scopes)
        local_merged, pull_report = apply_server_slice(local_next, info["_remote_slice"], target["name"], scopes, args.tag, args.conflict)
        remote_merged, push_report = apply_server_slice(info["_remote_data"], info["_local_slice"], target["name"], scopes, args.tag, args.conflict)
        item = {**strip_internal_sync_report(info), "pull_changes": pull_report, "push_changes": push_report, "would_write_local": report_has_changes(pull_report), "would_write_remote": report_has_changes(push_report)}
        reports.append(item)
        if report_has_errors(pull_report) or report_has_errors(push_report):
            emit({"operation": "bidir", "local_sidecar": str(path), "targets": reports, "ok": False}, args.json)
            raise SystemExit(1)
        local_next = local_merged
        if report_has_changes(push_report):
            remote_writes.append((target["server"], info["remote_sidecar"], remote_merged, item))
    local_write = atomic_write_json_with_backup(path, local_next, args.dry_run) if any(r.get("would_write_local") for r in reports) else {"wrote": False, "dry_run": args.dry_run}
    for spec, remote_sidecar, remote_data, item in remote_writes:
        item["remote_write"] = write_remote_sidecar(spec, args.prefer, remote_sidecar, remote_data, args.dry_run, args.timeout)
    emit({"operation": "bidir", "local_sidecar": str(path), "local_write": local_write, "targets": reports, "ok": True}, args.json)


