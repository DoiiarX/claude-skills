    shortcuts = data.get("shortcuts", {})
    if not isinstance(shortcuts, dict):
        return None
    bucket = shortcuts.get(category, {})
    if not isinstance(bucket, dict):
        return None
    spec = bucket.get(name)
    return spec if isinstance(spec, dict) else None


