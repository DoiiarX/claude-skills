def cmd_shortcut_run(args: argparse.Namespace) -> None:
    path = resolve_sidecar_path(args.sidecar)
    data = load_sidecar_path(path)
    spec = resolve_shortcut(data, args.category, args.name)
    if not spec:
        raise SystemExit(f"Shortcut not found: {args.category}/{args.name}. Try: server-md shortcut list --category {args.category} --json")
    execution = ensure_execution_config(data)
    command = str(spec.get("command", ""))
    mode = args.execute_mode or str(spec.get("execute_mode") or execution.get("default_mode") or "render")
    risk = str(spec.get("risk", "read-only"))
    log_path = args.log or str(execution.get("log", "~/.server-md/ops.jsonl"))
    base_event = {
        "event": "shortcut_run",
        "sidecar": str(path),
        "category": args.category,
        "name": args.name,
        "host": spec.get("host"),
        "risk": risk,
        "execute_mode": mode,
        "command_hash": command_hash(command),
    }
    if mode != "auto":
        append_jsonl(log_path, {**base_event, "outcome": "rendered"})
        emit({**base_event, "command": command, "executed": False, "log": log_path, "note": "execute_mode is not auto; command rendered only."}, args.json)
        return
    if shortcut_requires_confirmation(spec):
        expected_codes = valid_confirmation_codes(str(execution.get("confirm_salt", "")), args.category, args.name, command)
        if args.confirm_code not in expected_codes:
            append_jsonl(log_path, {**base_event, "outcome": "blocked_confirmation_required"})
            emit({
                **base_event,
                "executed": False,
                "blocked": True,
                "reason": "confirmation required",
                "log": log_path,
                "next_step": f"Ask the user to run shortcut challenge for {args.category}/{args.name} and provide the confirm code.",
            }, args.json)
            sys.exit(2)
    append_jsonl(log_path, {**base_event, "outcome": "started"})
    completed = subprocess.run(command, shell=True, text=True, capture_output=True, timeout=args.timeout)
    append_jsonl(log_path, {**base_event, "outcome": "completed", "returncode": completed.returncode})
    emit({
        **base_event,
        "executed": True,
        "returncode": completed.returncode,
        "stdout": completed.stdout[-args.output_limit:],
        "stderr": completed.stderr[-args.output_limit:],
        "log": log_path,
    }, args.json)
    if completed.returncode:
        sys.exit(completed.returncode)


