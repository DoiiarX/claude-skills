def extract_reveal_selectors(argv: list[str]) -> tuple[list[str], list[str] | None]:
    if "--reveal" not in argv:
        return argv, None
    idx = argv.index("--reveal")
    cleaned = argv[:idx] + ["--reveal"]
    selectors: list[str] = []
    j = idx + 1
    command_names = set(COMMAND_TREE)
    while j < len(argv):
        token = argv[j]
        if token.startswith("-") or token in command_names:
            break
        selectors.append(token)
        j += 1
    cleaned += argv[j:]
    return cleaned, selectors


def main() -> None:
    global REVEAL_ALL, REVEAL_SELECTORS
    argv, reveal_selectors = extract_reveal_selectors(sys.argv[1:])
    hint = command_hint(argv)
    if hint:
        print(f"server-md: {hint}", file=sys.stderr)
        raise SystemExit(2)
    parser = build_parser()
    args = parser.parse_args(argv)
    if getattr(args, "reveal", False):
        if reveal_selectors:
            REVEAL_SELECTORS = {normalize_reveal_selector(item) for item in reveal_selectors}
        else:
            REVEAL_ALL = True
    args.func(args)


if __name__ == "__main__":
    main()
