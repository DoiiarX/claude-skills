def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="server-md", description="Query and maintain server-md.json sidecar data; SERVER.md is informational only.")
    p.add_argument("--reveal", action="store_true", help="Reveal secret-like values in output; default masks them.")
    sub = p.add_subparsers(dest="cmd", required=True)

    locate = sub.add_parser("locate", help="Locate canonical sidecar and informational SERVER.md path.")
    locate.add_argument("--verbose", action="store_true", help="Include all candidates and sidecar details.")
    locate.add_argument("--json", action="store_true", help="Emit JSON.")
    locate.set_defaults(func=cmd_locate)

    env = sub.add_parser("env", help="Describe current host environment.")
    env.add_argument("--json", action="store_true", help="Emit JSON.")
    env.set_defaults(func=lambda a: emit(detect_env(), a.json))

    red = sub.add_parser("redact-check", help="Scan files for likely secrets before publishing.")
    red.add_argument("paths", nargs="+", help="Files or directories to scan.")
    red.add_argument("--fix", action="store_true", help="Mask detected secret-like values in place.")
    red.add_argument("--json", action="store_true", help="Emit JSON.")
    red.set_defaults(func=cmd_redact_check)

    res = sub.add_parser("resource", help="Register and find important server projects, directories, repos, configs, and data paths.")
    res_sub = res.add_subparsers(dest="resource_cmd", required=True)

    res_list = res_sub.add_parser("list", help="List important resources with limit and filters.")
    res_list.add_argument("--sidecar", help="server-md.json path; defaults to canonical sidecar.")
    res_list.add_argument("--server", help="Filter by server name or alias.")
    res_list.add_argument("--kind", choices=["project", "directory", "repo", "config", "data", "backup", "service", "other"], help="Filter by resource kind.")
    res_list.add_argument("--tag", action="append", help="Filter by tag; repeatable.")
    res_list.add_argument("--filter", help="Case-insensitive substring filter across resource record.")
    add_state_filter_args(res_list)
    add_limit_args(res_list)
    res_list.add_argument("--json", action="store_true", help="Emit JSON.")
    res_list.set_defaults(func=cmd_resource_list)

    res_add = res_sub.add_parser("add", help="Register or update one important resource.")
    res_add.add_argument("--sidecar", help="server-md.json path; defaults to canonical sidecar.")
    res_add.add_argument("--name", required=True)
    res_add.add_argument("--server", help="Server name or alias this resource belongs to.")
    res_add.add_argument("--kind", choices=["project", "directory", "repo", "config", "data", "backup", "service", "other"], default="directory")
    res_add.add_argument("--path", help="Path on the server or local machine.")
    res_add.add_argument("--url", help="Related URL, if any.")
    res_add.add_argument("--description")
    res_add.add_argument("--owner")
    res_add.add_argument("--notes-file")
    res_add.add_argument("--risk", choices=["read-only", "low", "medium", "high"], default="read-only")
    add_state_write_args(res_add)
    res_add.add_argument("--warning", action="append", help="Resource warning; repeatable.")
    res_add.add_argument("--tip", action="append", help="Resource tip; repeatable.")
    res_add.add_argument("--constraint", action="append", help="Resource constraint; repeatable.")
    res_add.add_argument("--tag", action="append")
    res_add.add_argument("--dry-run", action="store_true", help="Preview without writing.")
    res_add.add_argument("--force", action="store_true", help="Update existing resource.")
    res_add.add_argument("--json", action="store_true", help="Emit JSON.")
    res_add.set_defaults(func=cmd_resource_add)

    res_show = res_sub.add_parser("show", help="Show one important resource.")
    res_show.add_argument("--sidecar", help="server-md.json path; defaults to canonical sidecar.")
    res_show.add_argument("--name", required=True)
