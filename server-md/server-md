def command_hint(argv: list[str]) -> str | None:
    if not argv:
        return None
    if any(arg == "--revel" for arg in argv):
        return "Unknown option '--revel'. Did you mean '--reveal'? Usage: server-md --reveal <subcommand> ..."
    if any(arg == "--revert" for arg in argv):
        return "Unknown option '--revert'. For revealing masked values use '--reveal' before the subcommand."

    tokens = [arg for arg in argv if not arg.startswith("-")]
    if not tokens:
        return None
    top = tokens[0]
    if top not in COMMAND_TREE:
        choices = list(COMMAND_TREE)
        close = difflib.get_close_matches(top, choices, n=3, cutoff=0.45)
        suffix = f" Did you mean: {', '.join(close)}?" if close else f" Valid commands: {', '.join(choices)}."
        return f"Unknown command '{top}'.{suffix}"

    subcommands = COMMAND_TREE[top]
    if not subcommands:
        return None
    if len(tokens) < 2:
        return None
    sub = tokens[1]
    if sub not in subcommands:
        full = [f"{top} {name}" for name in subcommands]
        close = difflib.get_close_matches(f"{top} {sub}", full, n=3, cutoff=0.45)
        if not close:
            close_names = difflib.get_close_matches(sub, subcommands, n=3, cutoff=0.45)
            close = [f"{top} {name}" for name in close_names]
        suffix = f" Did you mean: {', '.join(close)}?" if close else f" Valid subcommands: {', '.join(full)}."
        return f"Unknown command '{top} {sub}'.{suffix}"
    return None

def normalize_reveal_selector(raw: str) -> str:
    value = raw.strip()
    if re.fullmatch(r"__MASKED_[A-Z0-9_]+_[0-9a-f]{10}__", value):
        return value
    return canonical_mask_type(value)


